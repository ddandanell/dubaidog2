{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd artifacts/pawclearance && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/pawclearance/dist",
  "devCommand": "cd artifacts/pawclearance && pnpm run dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  }
}
